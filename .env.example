# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# Optional: override default SQLite path with PostgreSQL for production
# DATABASE_URL=postgresql://user:password@localhost:5432/foreclosed_properties

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Daily scheduler run time (24h, Philippine time)
SCHEDULE_TIME=09:00

# HTTP settings
REQUEST_TIMEOUT=60
REQUEST_RETRY_COUNT=3
